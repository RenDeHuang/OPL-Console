{
  "schemaVersion": 1,
  "owner": "OPL Fabric boundary consumed by OPL Console",
  "purpose": "Stable API shape for Console governance calls into the v1 in-process Fabric adapter and future standalone OPL Fabric service.",
  "lifecycle": "current",
  "boundary": {
    "consoleUsesFor": [
      "Managed compute policy and lifecycle",
      "Managed storage policy and lifecycle",
      "Managed attachment lifecycle",
      "Managed workspace route handoff",
      "Managed storage backup and restore",
      "Managed connector and environment approval status",
      "Runtime readiness and runtime status for governed resources"
    ],
    "consoleDoesNotOwn": [
      "Fabric platform catalog truth",
      "Connect implementation",
      "Environment execution engine",
      "Gateway/App/Workspace adapters outside managed policy",
      "User-provided SSH, HPC, local, or unmanaged resources"
    ]
  },
  "operations": [
    "ListCatalog",
    "RuntimeReadiness",
    "CreateCompute",
    "StopCompute",
    "RestartCompute",
    "DestroyCompute",
    "CreateStorage",
    "AttachStorage",
    "DetachStorage",
    "DestroyStorage",
    "CreateStorageBackup",
    "RestoreStorageBackup",
    "CreateWorkspaceRoute",
    "DestroyWorkspaceRoute",
    "ResetWorkspaceToken",
    "DeleteWorkspaceToken",
    "RuntimeStatus"
  ]
}
