{
  "schemaVersion": 1,
  "owner": "OPL Console",
  "purpose": "Console route contract split from OPL-Cloud packages/console. This file fixes the Go/React rewrite to the current OPL-Cloud Console route truth.",
  "lifecycle": "current",
  "sourceTruth": {
    "repository": "RenDeHuang/OPL-Cloud",
    "apiManifest": "packages/console/api/routes/index.js",
    "routeContract": "packages/contracts/opl-cloud-route-api-contract.json"
  },
  "boundary": {
    "routeOwnership": "Console owns the control API surface and UI routes. Fabric and Ledger remain execution/truth ports behind these routes.",
    "noCompatibilityLayer": "Routes not present in the OPL-Cloud Console manifest are not exposed for compatibility.",
    "fabricPort": "compute/storage/attachment/route/runtime/backup execution",
    "ledgerPort": "topup/usage/reconciliation/task receipt evidence"
  },
