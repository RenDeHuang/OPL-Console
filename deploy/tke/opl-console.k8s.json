{
  "apiVersion": "v1",
  "kind": "List",
  "items": [
    {
      "apiVersion": "v1",
      "kind": "Namespace",
      "metadata": {
        "name": "opl-cloud",
        "labels": {
          "app.kubernetes.io/name": "opl-console"
        }
      }
    },
    {
      "apiVersion": "v1",
      "kind": "ConfigMap",
      "metadata": {
        "name": "opl-console-config",
        "namespace": "opl-cloud"
      },
      "data": {
        "OPL_CONSOLE_ADDR": "0.0.0.0:8787",
        "OPL_PUBLIC_URL": "https://cloud.medopl.cn",
        "OPL_WORKSPACE_DOMAIN": "workspace.medopl.cn",
        "OPL_FABRIC_PROVIDER": "tke",
        "OPL_K8S_NAMESPACE": "opl-cloud",
        "OPL_INGRESS_CLASS": "qcloud",
        "OPL_WORKSPACE_IMAGE": "registry.example.com/opl/one-person-lab-app:2026-07-04",
        "OPL_WORKSPACE_STORAGE_CLASS": "cbs"
      }
    },
    {
      "apiVersion": "v1",
      "kind": "ServiceAccount",
      "metadata": {
        "name": "opl-console",
        "namespace": "opl-cloud"
      }
    },
    {
      "apiVersion": "rbac.authorization.k8s.io/v1",
      "kind": "Role",
      "metadata": {
        "name": "opl-console-runtime-manager",
        "namespace": "opl-cloud"
      },
      "rules": [
        {
          "apiGroups": [""],
          "resources": ["services", "persistentvolumeclaims", "secrets"],
          "verbs": ["get", "list", "create", "update", "delete"]
        },
        {
          "apiGroups": ["apps"],
          "resources": ["deployments"],
          "verbs": ["get", "list", "create", "update", "delete"]
        },
        {
          "apiGroups": ["networking.k8s.io"],
          "resources": ["ingresses"],
          "verbs": ["get", "list", "create", "update", "delete"]
        }
      ]
    },
    {
      "apiVersion": "rbac.authorization.k8s.io/v1",
      "kind": "RoleBinding",
      "metadata": {
        "name": "opl-console-runtime-manager",
        "namespace": "opl-cloud"
      },
      "subjects": [
        {
          "kind": "ServiceAccount",
          "name": "opl-console",
          "namespace": "opl-cloud"
        }
      ],
      "roleRef": {
        "apiGroup": "rbac.authorization.k8s.io",
        "kind": "Role",
        "name": "opl-console-runtime-manager"
      }
    },
    {
      "apiVersion": "apps/v1",
      "kind": "Deployment",
      "metadata": {
        "name": "opl-console",
        "namespace": "opl-cloud"
      },
      "spec": {
        "replicas": 1,
        "selector": {
          "matchLabels": {
            "app.kubernetes.io/name": "opl-console"
          }
        },
        "template": {
          "metadata": {
            "labels": {
              "app.kubernetes.io/name": "opl-console"
            }
          },
          "spec": {
            "serviceAccountName": "opl-console",
            "automountServiceAccountToken": true,
            "containers": [
              {
                "name": "console",
                "image": "registry.example.com/opl/opl-console:2026-07-04",
                "ports": [
                  {
                    "name": "http",
                    "containerPort": 8787
                  }
                ],
                "envFrom": [
                  {
                    "configMapRef": {
                      "name": "opl-console-config"
                    }
                  }
                ],
                "env": [
                  {
                    "name": "DATABASE_URL",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-console-database",
                        "key": "DATABASE_URL"
                      }
                    }
                  },
                  {
                    "name": "OPL_CONSOLE_USERS_JSON",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-console-auth",
                        "key": "OPL_CONSOLE_USERS_JSON"
                      }
                    }
                  },
                  {
                    "name": "OPL_SESSION_COOKIE_NAME",
                    "value": "opl_console_session"
                  }
                ],
                "readinessProbe": {
                  "httpGet": {
                    "path": "/api/production/readiness",
                    "port": 8787
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10
                },
                "livenessProbe": {
                  "httpGet": {
                    "path": "/api/healthz",
                    "port": 8787
                  },
                  "initialDelaySeconds": 20,
                  "periodSeconds": 20
                },
                "securityContext": {
                  "allowPrivilegeEscalation": false,
                  "readOnlyRootFilesystem": true,
                  "capabilities": {
                    "drop": ["ALL"]
                  }
                },
                "volumeMounts": [
                  {
                    "name": "tmp",
                    "mountPath": "/tmp"
                  }
                ]
              }
            ],
            "volumes": [
              {
                "name": "tmp",
                "emptyDir": {}
              }
            ]
          }
        }
      }
    },
    {
      "apiVersion": "v1",
      "kind": "Service",
      "metadata": {
        "name": "opl-console",
        "namespace": "opl-cloud"
      },
      "spec": {
        "type": "ClusterIP",
        "selector": {
          "app.kubernetes.io/name": "opl-console"
        },
        "ports": [
          {
            "name": "http",
            "port": 8787,
            "targetPort": "http"
          }
        ]
      }
    }
  ]
}
