{
  "apiVersion": "v1",
  "kind": "List",
  "items": [
    {
      "apiVersion": "v1",
      "kind": "Namespace",
      "metadata": {
        "name": "opl-cloud",
        "labels": {
          "app.kubernetes.io/name": "opl-console"
        }
      }
    },
    {
      "apiVersion": "v1",
      "kind": "ConfigMap",
      "metadata": {
        "name": "opl-console-config",
        "namespace": "opl-cloud"
      },
      "data": {
        "OPL_CONSOLE_ADDR": "0.0.0.0:8787",
        "OPL_PUBLIC_URL": "https://cloud.medopl.cn",
        "OPL_WORKSPACE_DOMAIN": "workspace.medopl.cn",
        "OPL_K8S_NAMESPACE": "opl-cloud",
        "OPL_INGRESS_CLASS": "qcloud",
        "OPL_WORKSPACE_IMAGE": "registry.example.com/opl/one-person-lab-app:2026-07-04",
        "OPL_WORKSPACE_STORAGE_CLASS": "cbs"
      }
    },
    {
      "apiVersion": "apps/v1",
      "kind": "Deployment",
      "metadata": {
        "name": "opl-console",
        "namespace": "opl-cloud"
      },
      "spec": {
        "replicas": 1,
        "selector": {
          "matchLabels": {
            "app.kubernetes.io/name": "opl-console"
          }
        },
        "template": {
          "metadata": {
            "labels": {
              "app.kubernetes.io/name": "opl-console"
            }
          },
          "spec": {
            "automountServiceAccountToken": false,
            "containers": [
              {
                "name": "console",
                "image": "registry.example.com/opl/opl-console:2026-07-04",
                "ports": [
                  {
                    "name": "http",
                    "containerPort": 8787
                  }
                ],
                "envFrom": [
                  {
                    "configMapRef": {
                      "name": "opl-console-config"
                    }
                  }
                ],
                "env": [
                  {
                    "name": "DATABASE_URL",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-console-database",
                        "key": "DATABASE_URL"
                      }
                    }
                  },
                  {
                    "name": "OPL_CONSOLE_USERS_JSON",
                    "valueFrom": {
                      "secretKeyRef": {
                        "name": "opl-console-auth",
                        "key": "OPL_CONSOLE_USERS_JSON"
                      }
                    }
                  },
                  {
                    "name": "KUBECONFIG",
                    "value": "/var/run/opl-console/kubeconfig/kubeconfig"
                  }
                ],
                "readinessProbe": {
                  "httpGet": {
                    "path": "/api/production/readiness",
                    "port": 8787
                  },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 10
                },
                "livenessProbe": {
                  "httpGet": {
                    "path": "/api/healthz",
                    "port": 8787
                  },
                  "initialDelaySeconds": 20,
                  "periodSeconds": 20
                },
                "securityContext": {
                  "allowPrivilegeEscalation": false,
                  "readOnlyRootFilesystem": true,
                  "capabilities": {
                    "drop": ["ALL"]
                  }
                },
                "volumeMounts": [
                  {
                    "name": "deploy-kubeconfig",
                    "mountPath": "/var/run/opl-console/kubeconfig",
                    "readOnly": true
                  },
                  {
                    "name": "tmp",
                    "mountPath": "/tmp"
                  }
                ]
              }
            ],
            "volumes": [
              {
                "name": "deploy-kubeconfig",
                "secret": {
                  "secretName": "opl-console-deploy-kubeconfig"
                }
              },
              {
                "name": "tmp",
                "emptyDir": {}
              }
            ]
          }
        }
      }
    },
    {
      "apiVersion": "v1",
      "kind": "Service",
      "metadata": {
        "name": "opl-console",
        "namespace": "opl-cloud"
      },
      "spec": {
        "type": "ClusterIP",
        "selector": {
          "app.kubernetes.io/name": "opl-console"
        },
        "ports": [
          {
            "name": "http",
            "port": 8787,
            "targetPort": "http"
          }
        ]
      }
    }
  ]
}
